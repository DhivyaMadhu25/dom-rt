# DOM-RT Backend — Environment Variables
# ─────────────────────────────────────────────────────────
# SETUP INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in all values marked <CHANGE_THIS>
#   3. NEVER commit your .env file to version control
#
# The .gitignore already excludes .env files.
# ─────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=domrt
DB_USER=<CHANGE_THIS>           # e.g. domrt_user
DB_PASSWORD=<CHANGE_THIS>       # Use a strong password in production

# ── JWT Authentication ───────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=<CHANGE_THIS>
JWT_EXPIRES_IN=8h

# ── AI Service ───────────────────────────────────────────
AI_SERVICE_URL=http://localhost:5001

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Scheduler ────────────────────────────────────────────
# Set to 'false' to disable background site auto-reporting
AUTO_SCHEDULER=true
