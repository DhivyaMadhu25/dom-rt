# ─── Environment & Secrets ──────────────────────────────
# NEVER commit these files — they contain credentials
.env
.env.local
.env.development
.env.production
.env.staging
*.env

# ─── Environment Examples (safe to commit) ──────────────
# .env.example files ARE committed — they show required vars
# without real values

# ─── Node.js ─────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity

# ─── Python / AI Service ─────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/

# ─── AI Model Files (large binaries — use releases) ──────
ai/model/*.pkl
ai/model/*.json
ai/model/*.joblib

# ─── Database ────────────────────────────────────────────
*.sql.bak
postgres_data/
*.dump

# ─── IDE / OS ────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ─── Docker ──────────────────────────────────────────────
docker-compose.override.yml

# ─── Logs ────────────────────────────────────────────────
logs/
*.log

# ─── Build Output ────────────────────────────────────────
frontend/dist/
frontend/build/
